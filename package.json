{
  "name": "filedb-typescript",
  "version": "1.0.0",
  "description": "File-based JSON database module written in TypeScript",
  "main": "dist/fileDB/index.js",
  "types": "dist/fileDB/index.d.ts",
  "scripts": {
    "build": "npm run build:server",
    "build:server": "tsc",
    "build:client": "npm --prefix client run build",
    "build:all": "npm run build:server && npm run build:client",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "npm run build:server && node dist/test.js",
    "dev": "ts-node src/test.ts",
    "server-dev": "ts-node src/server/index.ts",
    "server": "npm run build && node dist/server/index.js",
    "db:migrate": "ts-node src/server/database/runMigrations.ts",
    "db:seed": "ts-node src/server/database/seed.ts",
    "pg:create-table": "node createTable.js",
    "pg:get-all": "node getAll.js",
    "pg:get-by-id": "node getById.js",
    "pg:insert": "node insert.js",
    "pg:update": "node update.js",
    "pg:delete": "node delete.js",
    "videos:create-table": "node videos-scripts/createTable.js",
    "videos:insert": "node videos-scripts/insert.js",
    "videos:paginate": "node videos-scripts/paginate.js",
    "videos:find": "node videos-scripts/find.js",
    "videos:group": "node videos-scripts/group.js",
    "videos:top": "node videos-scripts/top.js"
  },
  "keywords": [
    "database",
    "filedb",
    "json",
    "typescript"
  ],
  "author": "Ksenia",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "ts-node": "^10.0.0",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "ajv": "^8.18.0",
    "bcrypt": "^6.0.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
